# Umami Analytics Configuration
# Copy this file to .env.local and fill in your values

# Backend API auth key — sent as the `x-auth-key` header on every server-side
# request to api.park.fan. Server-only (NOT NEXT_PUBLIC_): the key is never
# exposed to the browser; client requests go through the Next.js proxy routes.
# API_AUTH_KEY=

# Umami Analytics Script URL (default: cloud.umami.is)
NEXT_PUBLIC_UMAMI_URL=https://cloud.umami.is/script.js

# Your Umami Website ID from the dashboard
NEXT_PUBLIC_UMAMI_WEBSITE_ID=563fb5d1-2006-4e93-b2bd-439869690ebe

# Feature flags (see lib/config/features.ts) — default OFF when unset.
# Enable the animated three.js RollerCoaster-Tycoon-style 3-D park hero on the
# homepage (off → classic rotating hero photo). Accepts 1 / true / on / yes.
# NEXT_PUBLIC_HERO_3D=on

# Vercel Toolbar + Flags Explorer (for debug geo override)
# Toolbar appears automatically on Vercel deployments (preview/production).
# 1. Run "vercel link" to link this project to Vercel.
# 2. Deploy or open a preview, open Flags Explorer in the toolbar, complete setup to create FLAGS_SECRET.
# 3. Run "vercel env pull" to get FLAGS_SECRET locally (for local dev with toolbar, if needed).
# Use the toolbar's Flags Explorer to override "debug-geo-mode": Real / Near Phantasialand / In Phantasialand.
# FLAGS_SECRET is required for Flags Explorer (discovery + override cookie). Must be 32 bytes, base64url.
# Create via Flags Explorer "Create secret" or: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# FLAGS_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# User photo contributions (/[locale]/contribute)
# ──────────────────────────────────────────────────────────────────────────────

# Cloudflare Turnstile — bot protection for the upload form (verified once in
# /api/contribute/start). Get the keys at https://dash.cloudflare.com → Turnstile.
# Public site key (browser widget). If unset, the prototype uses Cloudflare's
# always-passes TEST key so the form still renders in local dev.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Secret key (server-only, used to verify the token). If unset, verification is
# SKIPPED in dev and HARD-FAILS in production (never silently open).
# TURNSTILE_SECRET_KEY=

# Storage: photos are proxied THROUGH our server to a PRIVATE Vercel Blob store
# (one request per file, each downscaled client-side to stay under Vercel's ~4.5 MB
# body limit — the browser never pushes to Blob directly). Submission metadata (the
# moderation queue) is stored as JSON in the same store.
# These are provided automatically when you link a Vercel Blob store to the project:
# BLOB_READ_WRITE_TOKEN=
# BLOB_STORE_ID=
# BLOB_WEBHOOK_PUBLIC_KEY=
# Storage driver override. Auto-detects 'vercel-blob' when BLOB_READ_WRITE_TOKEN is
# present, else 'local' (writes to ./.uploads + ./.data — offline dev only). Force with:
# STORAGE_DRIVER=local
# Secret used to HMAC-sign the short-lived upload tickets. Optional — falls back to
# BLOB_READ_WRITE_TOKEN. Set a dedicated value to rotate independently:
# CONTRIBUTE_TICKET_SECRET=
