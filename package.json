  "scripts": {
    "dev": "next dev --turbopack",
    "dev:live": "node scripts/dev-live.mjs",
    "prebuild": "node scripts/generate-build-info.mjs && node scripts/generate-client-glossary.mjs && node scripts/generate-blog-manifest.mjs && pnpm generate:hero-images && pnpm generate:attraction-images",
    "build": "pnpm prebuild && next build --turbo",
    "analyze": "pnpm prebuild && cross-env ANALYZE=true next build --webpack",
    "build:webpack": "pnpm prebuild && next build --webpack",
    "generate:hero-images": "node scripts/generate-hero-images.mjs",
    "generate:hero-textures": "node scripts/fetch-hero-textures.mjs",
    "generate:attraction-images": "node scripts/generate-attraction-images.mjs",
    "generate:client-glossary": "node scripts/generate-client-glossary.mjs",
    "generate:blog-manifest": "node scripts/generate-blog-manifest.mjs",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:translations": "node scripts/validate-translations.js",
    "test:calendar": "node --experimental-strip-types --import ./scripts/register-path-alias.mjs scripts/test-calendar-utils.mjs",
    "probe:isr": "node scripts/isr-cache-probe.mjs",
    "crawl:translations": "node scripts/crawl-translations.js",
    "crawl:translations:live": "node scripts/crawl-translations.js --live",
    "test:translations": "npm run validate:translations && npm run build && npm run crawl:translations",
    "release:check": "pnpm lint && pnpm format:check && pnpm validate:translations",
    "impeccable:detect": "npx -y impeccable@3 detect app components lib",
    "impeccable:detect:ci": "npx -y impeccable@3 detect --json app components lib",
    "impeccable:install": "npx -y impeccable@3 install",
    "impeccable:update": "npx -y impeccable@3 update"
  },
